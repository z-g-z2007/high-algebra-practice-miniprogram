<view class="container">
  <view class="quote-card">
    <text class="quote-icon">❝</text>
    <text class="quote-text">{{quote}}</text>
    <text class="quote-author">—— {{author}}</text>
  </view>
  
  <view class="menu-list">
    <view class="menu-item" bindtap="goToLinearTransform">
      <view class="menu-left">
        <text class="menu-icon">📐</text>
        <view class="menu-text">
          <text class="menu-title">线性变换</text>
          <text class="menu-desc">2D/3D互动</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item" bindtap="goToElementaryTransform">
      <view class="menu-left">
        <text class="menu-icon">📊</text>
        <view class="menu-text">
          <text class="menu-title">初等变换</text>
          <text class="menu-desc">矩阵初等行变换实操</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>
  
  <view class="report-section">
    <view class="report-card" bindtap="goToReport">
      <view class="report-icon">📈</view>
      <view class="report-content">
        <text class="report-title">练习报告</text>
        <text class="report-desc">查看你的练习数据和进步</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>