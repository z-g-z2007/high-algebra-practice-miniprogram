.start-container {
  height: 100vh;
  background: #000;
  position: relative;
  overflow: hidden;
}

.ad-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.skip-box {
  position: absolute;
  top: 60rpx;
  right: 30rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 30rpx;
  padding: 15rpx 25rpx;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.skip-text {
  color: #fff;
  font-size: 28rpx;
}

.countdown-num {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

.app-info {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  z-index: 50;
}

.app-name {
  color: white;
  font-size: 48rpx;
  font-weight: bold;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.modal-content {
  background: white;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  width: 85%;
  max-width: 600rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.modal-header {
  margin-bottom: 30rpx;
}

.modal-icon-text {
  font-size: 80rpx;
}

.modal-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

.privacy-content {
  text-align: left;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.privacy-item {
  font-size: 24rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 15rpx;
}

.privacy-item:last-child {
  margin-bottom: 0;
}

.modal-btns {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
}

.btn.cancel {
  background: #f5f5f5;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

.btn.confirm {
  background: #1a73e8;
  color: white;
  border: none;
}
