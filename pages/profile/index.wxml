<view class="container">
  <view class="profile-header">
    <view class="avatar-section">
      <view class="avatar" style="{{isLoggedIn && userInfo.avatarUrl ? 'background-image: url(' + userInfo.avatarUrl + '); background-size: cover;' : ''}}">
        {{isLoggedIn ? (userInfo.avatarUrl ? '' : (userInfo.nickName.charAt(0) || '?')) : '?'}}
      </view>
      <text class="login-hint">{{isLoggedIn ? userInfo.nickName : '未登录'}}</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="section-title">账号服务</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="toggleLoginModal">
        <view class="menu-left">
          <text class="menu-icon">{{isLoggedIn ? '🔓' : '🔐'}}</text>
          <text class="menu-text">{{isLoggedIn ? '退出登录' : '登录/注册'}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="toggleQuestionModal">
        <view class="menu-left">
          <text class="menu-icon">📝</text>
          <text class="menu-text">为题库投稿</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="section-title">帮助与支持</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="showAboutUs">
        <view class="menu-left">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-text">关于我们</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="showHelpCenter">
        <view class="menu-left">
          <text class="menu-icon">❓</text>
          <text class="menu-text">帮助中心</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="showPrivacyPolicy">
        <view class="menu-left">
          <text class="menu-icon">🔒</text>
          <text class="menu-text">隐私政策</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="showUserAgreement">
        <view class="menu-left">
          <text class="menu-icon">📄</text>
          <text class="menu-text">用户协议</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="section-title">其他</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="checkForUpdate">
        <view class="menu-left">
          <text class="menu-icon">🔄</text>
          <text class="menu-text">检查更新</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="contactUs">
        <view class="menu-left">
          <text class="menu-icon">📧</text>
          <text class="menu-text">联系我们</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="version-info">
    <text class="version-text">线性代数练习 v1.0.0</text>
  </view>

  <view class="login-modal" wx:if="{{showLoginModal}}">
    <view class="modal-mask" bindtap="toggleLoginModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">登录</text>
        <text class="modal-close" bindtap="toggleLoginModal">x</text>
      </view>
      <view class="modal-body">
        <view class="login-methods">
          <view class="login-method" bindtap="wechatLogin">
            <text class="method-icon">💬</text>
            <text class="method-text">微信登录</text>
          </view>
          <view class="login-method" bindtap="phoneLogin">
            <text class="method-icon">📱</text>
            <text class="method-text">手机号登录</text>
          </view>
        </view>
        <view class="login-agreement">
          <text class="agreement-text">登录即表示同意</text>
          <text class="agreement-link" bindtap="showUserAgreement">用户协议</text>
          <text class="agreement-text">和</text>
          <text class="agreement-link" bindtap="showPrivacyPolicy">隐私政策</text>
        </view>
      </view>
    </view>
  </view>

  <view class="question-modal" wx:if="{{showQuestionModal}}">
    <view class="modal-mask" bindtap="toggleQuestionModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">题库投稿</text>
        <text class="modal-close" bindtap="toggleQuestionModal">x</text>
      </view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">题目类型</text>
          <picker class="picker-field" mode="selector" range="{{questionTypes}}" value="{{questionTypeIndex}}" bindchange="onQuestionTypeChange">
            <view class="picker-value">{{questionTypes[questionTypeIndex]}}</view>
          </picker>
        </view>
        <view class="input-group">
          <text class="input-label">难度等级</text>
          <picker class="picker-field" mode="selector" range="{{difficultyLevels}}" value="{{difficultyIndex}}" bindchange="onDifficultyChange">
            <view class="picker-value">{{difficultyLevels[difficultyIndex]}}</view>
          </picker>
        </view>
        <view class="input-group">
          <text class="input-label">作者姓名</text>
          <input class="input-field" type="text" placeholder="请输入作者姓名" value="{{authorName}}" bindinput="onAuthorNameInput" />
        </view>
        <view class="input-group">
          <text class="input-label">邮箱地址</text>
          <input class="input-field" type="text" placeholder="请输入邮箱地址" value="{{authorEmail}}" bindinput="onAuthorEmailInput" />
        </view>
        <view class="input-group">
          <text class="input-label">题目描述</text>
          <textarea class="textarea-field" placeholder="请输入题目内容" value="{{questionContent}}" bindinput="onQuestionContentInput"></textarea>
        </view>
        <view class="input-group">
          <text class="input-label">答案</text>
          <textarea class="textarea-field" placeholder="请输入答案" value="{{questionAnswer}}" bindinput="onQuestionAnswerInput"></textarea>
        </view>
        <button class="submit-btn" bindtap="handleSubmitQuestion">提交题目</button>
      </view>
    </view>
  </view>
</view>