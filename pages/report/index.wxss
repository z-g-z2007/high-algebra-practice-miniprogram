.report-container {
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.report-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid #e2e8f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  font-size: 44rpx;
  color: #333;
  font-weight: bold;
  line-height: 1;
  padding: 10rpx;
}

.report-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  width: 64rpx;
}

.report-content {
  padding: 30rpx 30rpx 140rpx;
}

.empty-wrong {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10rpx);
}

.empty-wrong-text {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 24rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.stats-section {
  margin-bottom: 40rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-item {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10rpx);
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #3b82f6;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #6b7280;
}

.trend-section {
  margin-bottom: 40rpx;
}

.chart-container {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10rpx);
}

.chart-grid {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  height: 200rpx;
  margin-top: 20rpx;
}

.chart-bar {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.bar {
  width: 100%;
  min-height: 4rpx;
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.5s ease;
}

.bar-label {
  font-size: 20rpx;
  color: #6b7280;
  text-align: center;
  line-height: 1;
}

.records-section {
  margin-bottom: 40rpx;
}

.wrong-section {
  margin-bottom: 40rpx;
}

.wrong-item {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10rpx);
  transition: all 0.2s ease;
  animation: fadeInUp 0.5s ease forwards;
}

.wrong-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.wrong-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.wrong-type {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
}

.wrong-time {
  font-size: 20rpx;
  color: #9ca3af;
}

.wrong-question {
  font-size: 22rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #ef4444;
}

.wrong-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.wrong-status {
  font-size: 20rpx;
  color: #ef4444;
  background: rgba(239, 68, 68, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.wrong-action {
  font-size: 22rpx;
  color: #3b82f6;
  font-weight: 500;
  padding: 8rpx 16rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 12rpx;
}

.wrong-action:active {
  background: rgba(59, 130, 246, 0.2);
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10rpx);
  transition: all 0.2s ease;
}

.record-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.record-type {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
  display: block;
}

.record-time {
  font-size: 20rpx;
  color: #9ca3af;
  display: block;
}

.record-score {
  font-size: 28rpx;
  font-weight: 600;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .stat-value {
    font-size: 32rpx;
  }
  
  .stat-label {
    font-size: 20rpx;
  }
}

/* 动画效果 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.stat-item, .chart-container, .record-item {
  animation: fadeInUp 0.5s ease forwards;
}

.stat-item:nth-child(1) { animation-delay: 0.1s; }
.stat-item:nth-child(2) { animation-delay: 0.2s; }
.stat-item:nth-child(3) { animation-delay: 0.3s; }
.stat-item:nth-child(4) { animation-delay: 0.4s; }

.chart-container { animation-delay: 0.5s; }

.record-item:nth-child(1) { animation-delay: 0.6s; }
.record-item:nth-child(2) { animation-delay: 0.7s; }
.record-item:nth-child(3) { animation-delay: 0.8s; }
.record-item:nth-child(4) { animation-delay: 0.9s; }
.record-item:nth-child(5) { animation-delay: 1.0s; }

.wrong-item:nth-child(1) { animation-delay: 1.1s; }
.wrong-item:nth-child(2) { animation-delay: 1.2s; }
.wrong-item:nth-child(3) { animation-delay: 1.3s; }