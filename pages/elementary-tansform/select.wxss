.container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  width: 100vw;
  max-width: 100vw;
  padding: 0 !important;
  margin: 0;
  overflow-x: hidden;
  overflow-y: auto;
  position: relative;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  min-width: 100vw;
  height: auto !important;
  box-sizing: border-box;
}

/* 重置默认样式 */
page {
  width: 100vw;
  height: 100vh;
  margin: 0;
  padding: 0;
  overflow: hidden;
  min-width: 100vw;
}

/* 强制子元素占满宽度 */
.container .header,
.container .content,
.container .start-area {
  min-width: 100vw;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  flex-shrink: 0;
  width: 100vw;
  max-width: 100vw;
  box-sizing: border-box;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  position: relative;
}

.back-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx;
}

.back-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
  position: relative;
  z-index: 1;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-right: 64rpx;
}

.header-right {
  width: 64rpx;
}

.content {
  padding: 24rpx 30rpx;
  padding-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100vw;
  max-width: 100vw;
  box-sizing: border-box;
  margin-bottom: 0;
  flex-shrink: 0;
  min-height: 0;
}

.section {
  background: #fff;
  border-radius: 0;
  padding: 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
  width: 100%;
  box-sizing: border-box;
  margin: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.size-group {
  display: flex;
  gap: 16rpx;
}

.size-btn {
  flex: 1;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border: 4rpx solid transparent;
  transition: all 0.3s ease;
  position: relative;
}

.size-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 16rpx;
}

.size-btn.active {
  background: #e8f0ff;
  border-color: #764ba2;
}

.size-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.size-num {
  font-size: 34rpx;
  font-weight: bold;
  color: #764ba2;
}

.size-desc {
  font-size: 22rpx;
  color: #666;
}

.target-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.target-btn {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 4rpx solid transparent;
  transition: all 0.3s ease;
  position: relative;
}

.target-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 16rpx;
}

.target-btn.active {
  background: #f3e8ff;
  border-color: #764ba2;
}

.target-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.target-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #764ba2;
  display: block;
  margin-bottom: 6rpx;
}

.target-desc {
  font-size: 24rpx;
  color: #666;
}

.rules-card {
  background: #fff;
  border-radius: 0;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
  flex-shrink: 0;
}

.rules-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}

.rule-icon {
  font-size: 32rpx;
  color: #764ba2;
  width: 50rpx;
  text-align: center;
}

.rule-text {
  font-size: 26rpx;
  color: #666;
}

.start-area {
  margin-top: 30rpx;
  flex-shrink: 0;
}

.start-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  padding: 36rpx;
  text-align: center;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
  position: relative;
}

.start-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50rpx;
}

.start-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.start-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}