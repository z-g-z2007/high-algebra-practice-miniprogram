page {
  width: 100%;
  min-height: 100vh;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  background: #f5f5f5;
  width: 100%;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  display: block;
}

.section {
  background: #fff;
  padding: 28rpx 32rpx;
  width: 100%;
  margin: 0;
  box-sizing: border-box;
  display: block;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin: 0 0 16rpx 0;
  padding: 0;
  display: block;
}

.option-group {
  display: flex;
  gap: 20rpx;
  margin: 0;
  padding: 0;
}

.option-group.three-col {
  gap: 16rpx;
}

.option-btn {
  flex: 1;
  background: #fff;
  border: 3rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.25s ease;
  margin: 0;
}

.option-btn.active {
  background: linear-gradient(135deg, #e8f0fe 0%, #d4e5ff 100%);
  border-color: #667eea;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.25);
}

.option-icon {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin: 0 0 8rpx 0;
  padding: 0;
}

.option-text {
  font-size: 24rpx;
  color: #666;
  margin: 0;
  padding: 0;
}

.difficulty-btn {
  flex: 1;
  background: #fff;
  border: 3rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 16rpx 10rpx;
  text-align: center;
  transition: all 0.25s ease;
  margin: 0;
}

.difficulty-btn.active {
  border-color: #4caf50;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.diff-name {
  font-size: 26rpx;
  color: #666;
  margin: 0;
  padding: 0;
}

.start-area {
  padding: 0 32rpx;
  margin: 0;
  background: #fff;
  width: 100%;
  box-sizing: border-box;
  display: block;
}

.reference-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  background: #fff;
  margin: 0;
  border: none;
}

.reference-btn:active {
  background: #f5f5f5;
}

.ref-icon {
  font-size: 32rpx;
  margin: 0 12rpx 0 0;
  padding: 0;
}

.ref-text {
  font-size: 28rpx;
  color: #667eea;
  margin: 0;
  padding: 0;
}

.start-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.4);
}

.start-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.start-text {
  font-size: 34rpx;
  font-weight: bold;
  margin: 0;
  padding: 0;
}