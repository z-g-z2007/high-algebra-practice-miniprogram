.container {
  width: 100vw;
  max-width: 100vw;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

/* 重置默认样式 */
page {
  width: 100vw;
  min-height: 100vh;
  margin: 0;
  padding: 0;
}

.canvas-section {
  width: 100vw;
  display: flex;
  justify-content: center;
  padding: 20rpx;
  box-sizing: border-box;
  background: #fafafa;
  margin-bottom: 20rpx;
}

.canvas-section.hidden {
  display: none;
}

.drawing-canvas {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.1);
  width: 700rpx !important;
  height: 700rpx !important;
  display: block;
}

.dimension-switch {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 32rpx;
  flex-shrink: 0;
  position: relative;
}

.dimension-switch::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx;
}

.dimension-switch:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.dimension-switch text {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.question-section {
  flex-shrink: 0;
  padding: 0;
  box-sizing: border-box;
  width: 100vw;
  max-width: 100vw;
}

.question-card {
  background: #fff;
  border-radius: 0;
  padding: 20rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  width: 100vw;
  max-width: 100vw;
  box-sizing: border-box;
  margin: 0;
}

.question-bar {
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.question-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.zoom-controls {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 100;
}

.zoom-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.zoom-btn:active {
  transform: scale(0.95);
  background: #f0f0f0;
}

.zoom-btn.reset {
  font-size: 28rpx;
}

.matrix-section {
  background: #fff;
  border-radius: 0;
  padding: 20rpx 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  width: 100vw;
  max-width: 100vw;
  box-sizing: border-box;
  margin: 0;
  margin-bottom: 0;
}

.matrix-section:last-child {
  margin-bottom: 0;
}

.matrix-display {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.matrix-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 14rpx;
  font-weight: 500;
}

.matrix-input {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.matrix-bracket {
  font-size: 48rpx;
  color: #667eea;
  font-weight: bold;
}

.matrix-card {
  background: linear-gradient(145deg, #f8f7fc, #f0eef8);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.08);
  border: 2rpx solid #ebe8f2;
  position: relative;
  overflow: hidden;
}

.matrix-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2, #667eea);
}

.matrix-input-row {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.matrix-grid {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.matrix-row {
  display: flex;
  gap: 10rpx;
}

.matrix-bracket {
  font-size: 56rpx;
  color: #667eea;
  font-weight: bold;
  line-height: 1;
  text-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.matrix-bracket.left {
  margin-right: 12rpx;
}

.matrix-bracket.right {
  margin-left: 12rpx;
}

.matrix-cell {
  width: 88rpx;
  height: 72rpx;
  border: 2rpx solid #d0cce0;
  border-radius: 12rpx;
  background: linear-gradient(145deg, #ffffff, #f8f6fc);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 30rpx;
  transition: all 0.3s ease;
}

.matrix-cell.correct {
  border-color: #22c55e;
  background: linear-gradient(145deg, rgba(34, 197, 94, 0.15), rgba(34, 197, 94, 0.05));
}

.matrix-cell.error {
  border-color: #ef4444;
  background: linear-gradient(145deg, rgba(239, 68, 68, 0.15), rgba(239, 68, 68, 0.05));
}

.matrix-cell.empty {
  border-color: #eab308;
  background: linear-gradient(145deg, rgba(234, 179, 8, 0.15), rgba(234, 179, 8, 0.05));
}

.matrix-cell.selected {
  border-color: #667eea;
  background: linear-gradient(145deg, #f0f4ff, #e8eeff);
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.2), 0 4rpx 12rpx rgba(102, 126, 234, 0.15);
  transform: scale(1.05);
}

.matrix-cell text {
  font-size: 30rpx;
}

.cell-input {
  width: 100%;
  height: 100%;
  text-align: center;
  font-size: 28rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 6rpx;
  background: #f8f8f8;
}

.action-section {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
  margin-top: 6rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  width: 100vw;
  max-width: 100vw;
}

.hint-btn,
.submit-btn,
.next-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.hint-btn {
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
  position: relative;
}

.hint-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.submit-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.submit-btn.correct {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
}

.next-btn {
  background: #fff;
  color: #333;
}

.next-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.hint-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.hint-content {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.hint-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #f8f8f8;
  border-bottom: 1rpx solid #eee;
}

.hint-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.hint-close {
  font-size: 40rpx;
  color: #999;
}

.hint-text {
  display: block;
  padding: 30rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.calc-process-section {
  margin: 16rpx 20rpx;
  padding: 24rpx 20rpx;
  background: linear-gradient(145deg, #fefefe, #f8f8ff);
  border-radius: 20rpx;
  border: 2rpx solid #e8e0f0;
  box-shadow: 0 4rpx 16rpx rgba(100, 80, 160, 0.08);
}

.calc-process-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx dashed #d8d0e8;
}

.calc-process-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #5a4a7a;
}

.calc-steps {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  font-family: 'Courier New', monospace;
}

.calc-step {
  padding: 4rpx 0;
}

.step-row {
  display: flex;
  align-items: center;
}

.step-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.9;
  font-family: 'Courier New', monospace;
  white-space: pre;
}

.label-text {
  color: #6a5a8a;
  font-weight: bold;
  font-size: 30rpx;
  margin: 12rpx 0 8rpx 0;
  display: block;
}

.result-text {
  color: #333;
  font-weight: 500;
}

.user-calc-input {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.calc-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
  background: linear-gradient(145deg, #fafafa, #f5f5f5);
  border: 2rpx solid #e8e0f0;
  border-radius: 12rpx;
  box-sizing: border-box;
  font-family: inherit;
}

.calc-textarea:focus {
  border-color: #9a8ac8;
  background: #fff;
  outline: none;
}

.calc-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #aaa;
  text-align: right;
}

.calc-template {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.calc-exercise {
  background: linear-gradient(145deg, #f8f8ff, #f0f0f8);
  border-radius: 12rpx;
  padding: 20rpx;
  margin: 16rpx 0;
}

.exercise-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.exercise-label {
  font-size: 26rpx;
  color: #666;
  font-weight: bold;
  width: 80rpx;
}

.exercise-op {
  font-size: 28rpx;
  color: #555;
  margin: 0 8rpx;
}

.exercise-val {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  min-width: 40rpx;
  text-align: center;
}

.small-input {
  width: 80rpx !important;
  height: 56rpx !important;
  font-size: 26rpx !important;
}

.template-section-title {
  font-size: 28rpx;
  color: #5a4a7a;
  font-weight: bold;
  margin: 24rpx 0 16rpx 0;
  padding-bottom: 10rpx;
  border-bottom: 2rpx dashed #d8d0e8;
}

.calc-fill-input {
  height: 64rpx;
  padding: 0 12rpx;
  font-size: 28rpx;
  font-family: 'Courier New', monospace;
  text-align: center;
  background: linear-gradient(145deg, #f8f8ff, #f0f0f8);
  border: 2rpx solid #d0d0e0;
  border-radius: 8rpx;
  margin: 0 6rpx;
}

.result-input {
  width: 100rpx !important;
  font-size: 28rpx !important;
  font-weight: bold;
  background: linear-gradient(145deg, #fff8e6, #fff0d0) !important;
  border-color: #e6d080 !important;
}

.result-label {
  font-size: 28rpx;
  color: #5a4a7a;
  font-weight: bold;
  margin-left: 8rpx;
}

.result-sep {
  font-size: 28rpx;
  color: #5a4a7a;
  font-weight: bold;
  margin: 0 5rpx;
}

.calc-result {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #e0d8f0;
}

.view-example-btn {
  margin-top: 20rpx;
  text-align: center;
  padding: 16rpx;
  background: linear-gradient(145deg, #f0eef8, #e8e4f0);
  border-radius: 12rpx;
  border: 1rpx dashed #c0b8d0;
}

.matrix-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.calc-toggle-btn {
  padding: 8rpx 20rpx;
  background: linear-gradient(145deg, #667eea, #5a6fd6);
  color: #fff;
  font-size: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.calc-toggle-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.cell-display {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  border: 2rpx solid #d0d0d0;
  border-radius: 8rpx;
  background: linear-gradient(145deg, #fafafa, #e8e8e8);
  color: #333;
  transition: all 0.2s ease;
}

.cell-display.selected {
  border: 2rpx solid #667eea;
  background: linear-gradient(145deg, #fff, #f0f4ff);
  box-shadow: 0 0 12rpx rgba(102, 126, 234, 0.6);
  transform: scale(1.05);
}

.custom-keyboard {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
  padding: 24rpx 16rpx 32rpx;
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.12);
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 1000;
}

.custom-keyboard.show {
  transform: translateY(0);
}

.keyboard-display {
  text-align: center;
  margin-bottom: 20rpx;
  padding: 0 20rpx;
}

.keyboard-title {
  font-size: 22rpx;
  color: #888;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.keyboard-current {
  font-size: 48rpx;
  color: #1a1a1a;
  font-weight: bold;
  padding: 16rpx 40rpx;
  background: linear-gradient(145deg, #ffffff, #f0f0f0);
  border-radius: 12rpx;
  display: inline-block;
  min-width: 200rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #e0e0e0;
}

.keyboard-keys {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 8rpx;
}

.key-row {
  display: flex;
  justify-content: center;
  gap: 10rpx;
}

.key-btn {
  width: 130rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffffff, #e6e6e6);
  border-radius: 12rpx;
  font-size: 38rpx;
  font-weight: 500;
  color: #333;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  transition: all 0.15s ease;
  border: 1rpx solid #d0d0d0;
}

.key-btn:active {
  transform: scale(0.92);
  background: linear-gradient(145deg, #e6e6e6, #d9d9d9);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.key-btn.key-op {
  background: linear-gradient(145deg, #f0f4ff, #dce4ff);
  color: #4a6cf7;
  border: 1rpx solid #b3c4ff;
}

.key-btn.key-op:active {
  background: linear-gradient(145deg, #dce4ff, #c4d4ff);
}

.key-btn.key-clear {
  background: linear-gradient(145deg, #ffeaea, #ffd9d9);
  color: #e74c3c;
  border: 1rpx solid #ffb3b3;
}

.key-btn.key-clear:active {
  background: linear-gradient(145deg, #ffd9d9, #ffcccc);
}

.key-btn.key-backspace {
  background: linear-gradient(145deg, #fff8e6, #ffefc2);
  color: #d4a200;
  border: 1rpx solid #ffe066;
}

.key-btn.key-backspace:active {
  background: linear-gradient(145deg, #ffefc2, #ffe066);
}

.key-btn.key-confirm {
  background: linear-gradient(145deg, #667eea, #5a6fd6);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
  border: none;
}

.key-btn.key-confirm:active {
  background: linear-gradient(145deg, #5a6fd6, #4a5fc6);
  transform: scale(0.92);
  box-shadow: 0 2rpx 6rpx rgba(102, 126, 234, 0.3);
}

.key-btn.key-zero {
  flex: 1;
  width: auto;
}

.answer-section {
  padding: 20rpx 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.process-card {
  background: linear-gradient(145deg, #f8f7fc, #f0eef8);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.08);
  border: 2rpx solid #ebe8f2;
  position: relative;
  overflow: hidden;
}

.process-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2, #667eea);
}

.process-card::after {
  content: '';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 100rpx;
  height: 100rpx;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.08) 0%, transparent 70%);
  border-radius: 50%;
}

.process-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 14rpx 0;
  position: relative;
  z-index: 1;
}

.process-row:last-child {
  margin-bottom: 0;
}

.process-label {
  width: 100rpx;
  font-size: 30rpx;
  color: #5a4a8a;
  font-weight: bold;
}

.calc-input {
  width: 88rpx;
  height: 76rpx;
  padding: 0 18rpx;
  font-size: 30rpx;
  font-family: 'Courier New', monospace;
  text-align: center;
  background: linear-gradient(145deg, #ffffff, #f5f4fa);
  border: 2rpx solid #d8d4e8;
  border-radius: 14rpx;
  margin: 0 6rpx;
  transition: all 0.25s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  vertical-align: middle;
  box-sizing: border-box;
  color: #333;
  font-weight: 500;
}

.calc-input text {
  font-size: 30rpx;
  text-align: center;
}

.calc-input.placeholder {
  color: #b8b4c8;
  background: linear-gradient(145deg, #fafafc, #f0eef8);
}

.calc-input.correct {
  border-color: #22c55e;
  background: linear-gradient(145deg, rgba(34, 197, 94, 0.15), rgba(34, 197, 94, 0.05));
}

.calc-input.error {
  border-color: #ef4444;
  background: linear-gradient(145deg, rgba(239, 68, 68, 0.15), rgba(239, 68, 68, 0.05));
}

.calc-input.empty {
  border-color: #eab308;
  background: linear-gradient(145deg, rgba(234, 179, 8, 0.15), rgba(234, 179, 8, 0.05));
}

.calc-input:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.15);
  transform: translateY(-2rpx);
}

.calc-input.sm {
  font-size: 26rpx;
  height: 68rpx;
}

.calc-input.result {
  background: linear-gradient(145deg, #ffffff, #f5f4fa);
  border-color: #d8d4e8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.calc-input.result-lg {
  width: 88rpx;
  height: 88rpx;
  font-size: 36rpx;
  background: linear-gradient(145deg, #ffffff, #f5f4fa);
  border-color: #d8d4e8;
}

.calc-input.result-lg.correct {
  border-color: #22c55e;
  background: linear-gradient(145deg, rgba(34, 197, 94, 0.15), rgba(34, 197, 94, 0.05));
}

.calc-input.result-lg.error {
  border-color: #ef4444;
  background: linear-gradient(145deg, rgba(239, 68, 68, 0.15), rgba(239, 68, 68, 0.05));
}

.calc-input.result-lg.empty {
  border-color: #eab308;
  background: linear-gradient(145deg, rgba(234, 179, 8, 0.15), rgba(234, 179, 8, 0.05));
}

.calc-input.result-lg text {
  font-size: 36rpx;
  text-align: center;
}

.calc-input.result-lg.placeholder {
  color: #d4b87a;
}

.op {
  font-size: 26rpx;
  color: #9a8ac8;
  margin: 0 5rpx;
  font-weight: 500;
}

.var-text {
  font-size: 30rpx;
  color: #5a4a8a;
  font-weight: bold;
}

.result-card {
  width: 94vw;
  margin: 0 auto;
  background: linear-gradient(145deg, #f8f7fc, #f0eef8);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.08);
  border: 2rpx solid #ebe8f2;
  position: relative;
  overflow: hidden;
}

.result-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2, #667eea);
}

.result-label {
  font-size: 34rpx;
  color: #5a4a8a;
  font-weight: bold;
}

.result-sep, .result-z {
  font-size: 34rpx;
  color: #9a8ac8;
  margin: 0 10rpx;
  font-weight: 500;
}

.control-row {
  display: flex;
  gap: 16rpx;
  width: 100vw;
  max-width: 100vw;
  box-sizing: border-box;
  padding: 0 20rpx;
  margin: 20rpx 0;
}

.ctrl-btn {
  flex: 1;
  background: #fff;
  border-radius: 50rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.ctrl-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: bold;
}

.ctrl-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2000;
}

.overlay-card {
  background: #fff;
  border-radius: 30rpx;
  padding: 60rpx 50rpx;
  text-align: center;
  width: 80%;
  max-width: 600rpx;
}

.result-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.result-steps {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 40rpx;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-btn {
  background: #f8f8f8;
  border-radius: 50rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  color: #667eea;
}

.result-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.answer-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2000;
}

.answer-modal {
  background: #fff;
  border-radius: 24rpx;
  width: 88%;
  max-height: 85vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.answer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.answer-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.answer-close {
  font-size: 48rpx;
  color: #fff;
  opacity: 0.8;
  line-height: 1;
}

.answer-close:active {
  opacity: 0.5;
}

.answer-body {
  flex: 1;
  padding: 24rpx;
  max-height: 70vh;
}

.answer-section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #5a4a8a;
  margin-bottom: 16rpx;
}

.answer-matrix-card {
  width: 100%;
  background: linear-gradient(145deg, #f8f7fc, #f0eef8);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: center;
  border: 2rpx solid #ebe8f2;
}

.answer-process-card {
  width: 100%;
  background: linear-gradient(145deg, #ffffff, #f8f7fc);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #ebe8f2;
}

.answer-process-card .process-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 12rpx 0;
  flex-wrap: wrap;
}

.answer-process-card .process-label {
  width: 80rpx;
  font-size: 28rpx;
  color: #5a4a8a;
  font-weight: bold;
}

.answer-process-card .op {
  font-size: 24rpx;
  color: #9a8ac8;
  margin: 0 4rpx;
}

.answer-process-card .var-text {
  font-size: 28rpx;
  color: #5a4a8a;
  font-weight: bold;
}

.answer-calc-val {
  min-width: 64rpx;
  height: 64rpx;
  padding: 0 12rpx;
  font-size: 28rpx;
  font-family: 'Courier New', monospace;
  text-align: center;
  background: linear-gradient(145deg, #fffbf0, #fff5e0);
  border: 2rpx solid #e6c080;
  border-radius: 10rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-weight: 500;
}

.answer-calc-val.sm {
  min-width: 52rpx;
  height: 52rpx;
  font-size: 24rpx;
}

.answer-result-card {
  width: 100%;
  background: linear-gradient(145deg, #f8f7fc, #f0eef8);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 2rpx solid #ebe8f2;
}

.answer-result-card .result-label {
  font-size: 32rpx;
  color: #5a4a8a;
  font-weight: bold;
}

.answer-result-card .result-sep,
.answer-result-card .result-z {
  font-size: 32rpx;
  color: #9a8ac8;
  margin: 0 8rpx;
}

.answer-result-val {
  min-width: 72rpx;
  height: 72rpx;
  padding: 0 14rpx;
  font-size: 32rpx;
  font-family: 'Courier New', monospace;
  text-align: center;
  background: linear-gradient(145deg, #fffbf0, #fff5e0);
  border: 2rpx solid #e6c080;
  border-radius: 12rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-weight: bold;
}

.ai-float-container {
  position: fixed;
  right: 30rpx;
  bottom: 200rpx;
  z-index: 999;
}

.ai-float-btn {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(145deg, #667eea, #764ba2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.5);
  animation: float 3s ease-in-out infinite;
}

.ai-float-btn::before {
  content: '';
  position: absolute;
  width: 120%;
  height: 120%;
  background: linear-gradient(145deg, rgba(102, 126, 234, 0.3), rgba(118, 75, 162, 0.2));
  border-radius: 50%;
  animation: pulse 2s ease-out infinite;
}

.ai-float-btn:hover {
  transform: scale(1.15);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.7);
}

.ai-float-btn.active {
  animation: bounce 0.5s ease-out;
}

.ai-float-icon {
  font-size: 48rpx;
  position: relative;
  z-index: 1;
  animation: bounce-icon 1s ease-in-out infinite;
}

.ai-float-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.ai-float-btn.hint {
  animation: shake 0.5s ease-in-out;
}

.ai-float-bubble {
  position: absolute;
  right: 110rpx;
  bottom: 50%;
  transform: translateY(50%);
  background: linear-gradient(145deg, #f8fafc, #f1f5f9);
  color: #334155;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  white-space: nowrap;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: 998;
  border: 1rpx solid #e2e8f0;
}

.ai-float-bubble.show {
  opacity: 1;
}

.ai-float-bubble::after {
  content: '';
  position: absolute;
  right: -12rpx;
  top: 50%;
  transform: translateY(-50%);
  border-left: 12rpx solid #f1f5f9;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-15rpx);
  }
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 0.6;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

@keyframes bounce {
  0% {
    transform: scale(1);
  }
  30% {
    transform: scale(1.2);
  }
  60% {
    transform: scale(0.9);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes bounce-icon {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

@keyframes shake {
  0%, 100% {
    transform: translateX(0);
  }
  20% {
    transform: translateX(-8rpx);
  }
  40% {
    transform: translateX(8rpx);
  }
  60% {
    transform: translateX(-8rpx);
  }
  80% {
    transform: translateX(8rpx);
  }
}
